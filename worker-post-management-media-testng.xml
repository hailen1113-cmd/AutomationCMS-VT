<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Media bai dang tho tren bon trang thai"
       verbose="1"
       preserve-order="true"
       parallel="false">
    <listeners>
        <listener class-name="com.vuatho.core.DriverLifecycleListener"/>
        <listener class-name="com.vuatho.reporting.ConsoleTestListener"/>
    </listeners>
    <test name="Xem anh va video tren tung tab">
        <classes>
            <class name="com.vuatho.tests.WorkerPostManagementMediaTest">
                <methods>
                    <include name="imageCanBeViewedInEveryStatus"/>
                    <include name="videoCanBeViewedInEveryStatus"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
