<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ERP Login and eKYC Suite" parallel="false" preserve-order="true"
       configfailurepolicy="continue">
    <listeners>
        <listener class-name="com.vuatho.reporting.ConsoleTestListener"/>
        <listener class-name="com.vuatho.tests.conditions.LogoutTestsEnabled"/>
        <listener class-name="com.vuatho.core.DriverLifecycleListener"/>
    </listeners>
    <test name="Login and eKYC checks">
        <classes>
            <class name="com.vuatho.tests.ErpLoginTest"/>
            <class name="com.vuatho.tests.EkycWorkbookCatalogTest"/>
            <class name="com.vuatho.tests.EkycApiContractTest"/>
            <class name="com.vuatho.tests.EkycApiTest"/>
        </classes>
    </test>
</suite>
